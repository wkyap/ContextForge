# ═══════════════════════════════════════════════════════
# ContextForge Engine — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ─── General ──────────────────────────────────────────
CONTEXTFORGE_ENV=development
CONTEXTFORGE_DEBUG=true
CONTEXTFORGE_LOG_LEVEL=INFO
CONTEXTFORGE_AUTH_DISABLED=true          # Set to false in production

# ─── PostgreSQL (App State + LangGraph Checkpointing) ─
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=contextforge
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=contextforge

# Connection string for LangGraph PostgresSaver/Store
CONTEXTFORGE_POSTGRES_URI=postgresql://contextforge:changeme_postgres@postgres:5432/contextforge

# ─── TimescaleDB (Time Series) ───────────────────────
TIMESCALE_HOST=timescaledb
TIMESCALE_PORT=5433
TIMESCALE_USER=contextforge
TIMESCALE_PASSWORD=changeme_timescale
TIMESCALE_DB=contextforge_ts

# ─── Neo4j (Temporal Knowledge Graph) ────────────────
NEO4J_HOST=neo4j
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_neo4j
NEO4J_URI=bolt://neo4j:7687

# ─── Qdrant (Vector Database) ────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=contextforge

# ─── Redis (Cache + Event Streams) ───────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis

# ─── ClickHouse (Langfuse Backend) ───────────────────
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=changeme_clickhouse

# ─── LiteLLM (LLM Gateway) ──────────────────────────
LITELLM_HOST=litellm
LITELLM_PORT=4000
LITELLM_MASTER_KEY=sk-litellm-master-key
LITELLM_BASE_URL=http://litellm:4000

# ─── LLM API Keys (configure at least one) ──────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ─── Ollama (Local LLM) ─────────────────────────────
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=phi4-mini

# ─── Langfuse (Observability) ────────────────────────
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_SECRET_KEY=sk-lf-changeme
LANGFUSE_PUBLIC_KEY=pk-lf-changeme
LANGFUSE_SALT=changeme_salt
LANGFUSE_NEXTAUTH_SECRET=changeme_nextauth
LANGFUSE_NEXTAUTH_URL=http://localhost:3001

# Langfuse database (uses main postgres)
LANGFUSE_DATABASE_URL=postgresql://contextforge:changeme_postgres@postgres:5432/langfuse

# ─── Keycloak (Authentication) ───────────────────────
KEYCLOAK_HOST=keycloak
KEYCLOAK_PORT=8180
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_keycloak
KEYCLOAK_REALM=contextforge
KEYCLOAK_CLIENT_ID=contextforge-api
KEYCLOAK_CLIENT_SECRET=changeme_client_secret
KEYCLOAK_ISSUER_URL=http://keycloak:8080/realms/contextforge

# ─── Embedding Model ────────────────────────────────
CONTEXTFORGE_EMBEDDING_MODEL=text-embedding-3-small
CONTEXTFORGE_EMBEDDING_DIM=1536

# ─── Re-ranker ──────────────────────────────────────
COHERE_API_KEY=
CONTEXTFORGE_RERANKER=cohere              # cohere | bge-reranker-v2

# ─── Sandbox (Tool Forge) ───────────────────────────
E2B_API_KEY=
CONTEXTFORGE_SANDBOX_PROVIDER=docker       # docker | e2b

# ─── Budget Defaults ────────────────────────────────
CONTEXTFORGE_MAX_TOKENS_PER_RUN=100000
CONTEXTFORGE_MAX_COST_PER_RUN_USD=5.00
CONTEXTFORGE_MAX_ITERATIONS=15
CONTEXTFORGE_MAX_TOOL_CALLS=25

# ─── Frontend ───────────────────────────────────────
CONTEXTFORGE_API_URL=http://localhost:8000
CONTEXTFORGE_WS_URL=ws://localhost:8000
